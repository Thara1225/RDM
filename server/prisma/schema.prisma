generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UnitType {
  yard
  kg
  piece
}

enum ShopOrderStatus {
  pending
  completed
  cancelled
}

model Admin {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(191)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Supplier {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(150)
  phone     String?    @db.VarChar(30)
  address   String?
  notes     String?
  createdAt DateTime   @default(now()) @map("created_at")
  purchases Purchase[]

  @@map("suppliers")
}

model Shop {
  id           Int           @id @default(autoincrement())
  name         String        @unique @db.VarChar(150)
  shopCode     String?       @unique @map("shop_code") @db.VarChar(50)
  phone        String?       @db.VarChar(30)
  address      String?
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  shopOrders   ShopOrder[]
  shopPayments ShopPayment[]

  @@map("shops")
}

model Material {
  id               Int               @id @default(autoincrement())
  name             String            @unique @db.VarChar(150)
  category         String?           @db.VarChar(100)
  color            String?           @db.VarChar(60)
  unitType         UnitType          @map("unit_type")
  photoUrl         String?           @map("photo_url")
  description      String?
  createdAt        DateTime          @default(now()) @map("created_at")
  purchases        Purchase[]
  cuttings         Cutting[]
  stock            Stock?
  stockAdjustments StockAdjustment[]

  @@map("materials")
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String      @unique @db.VarChar(150)
  category    String?     @db.VarChar(100)
  dressCode   String?     @map("dress_code") @db.VarChar(100)
  stockQty    Int         @default(0) @map("stock_qty")
  photoUrl    String?     @map("photo_url")
  description String?
  createdAt   DateTime    @default(now()) @map("created_at")
  shopOrders  ShopOrder[]
  cuttings    Cutting[]

  @@map("products")
}

model Purchase {
  id           Int      @id @default(autoincrement())
  supplierId   Int?     @map("supplier_id")
  materialId   Int?     @map("material_id")
  itemName     String?  @map("item_name") @db.VarChar(180)
  photoUrl     String?  @map("photo_url")
  quantity     Decimal  @db.Decimal(12, 3)
  unitPrice    Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalPrice   Decimal  @map("total_price") @db.Decimal(14, 2)
  purchaseDate DateTime @map("purchase_date") @db.Date
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  material Material? @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([supplierId])
  @@index([materialId])
  @@index([purchaseDate])
  @@map("purchases")
}

model Stock {
  id                Int      @id @default(autoincrement())
  materialId        Int      @unique @map("material_id")
  availableQuantity Decimal  @map("available_quantity") @db.Decimal(12, 3)
  minStockLevel     Decimal  @default(0) @map("min_stock_level") @db.Decimal(12, 3)
  updatedAt         DateTime @updatedAt @map("updated_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([availableQuantity])
  @@map("stock")
}

model ShopOrder {
  id         Int             @id @default(autoincrement())
  billNo     String?         @map("bill_no") @db.VarChar(50)
  shopId     Int             @map("shop_id")
  productId  Int             @map("product_id")
  quantity   Int
  unitPrice  Decimal         @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal         @map("total_price") @db.Decimal(14, 2)
  orderDate  DateTime        @map("order_date") @db.Date
  status     ShopOrderStatus @default(pending)
  notes      String?
  createdAt  DateTime        @default(now()) @map("created_at")

  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Restrict)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([shopId])
  @@index([billNo])
  @@index([productId])
  @@index([orderDate])
  @@index([status])
  @@map("shop_orders")
}

model Cutting {
  id            Int      @id @default(autoincrement())
  productId     Int      @map("product_id")
  materialId    Int      @map("material_id")
  quantityCut   Int      @map("quantity_cut")
  clothUsed     Decimal  @map("cloth_used") @db.Decimal(12, 3)
  wasteQuantity Decimal  @default(0) @map("waste_quantity") @db.Decimal(12, 3)
  cutDate       DateTime @map("cut_date") @db.Date
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  material Material @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([materialId])
  @@index([cutDate])
  @@map("cuttings")
}

model StockAdjustment {
  id          Int      @id @default(autoincrement())
  materialId  Int      @map("material_id")
  oldQuantity Decimal  @map("old_quantity") @db.Decimal(12, 3)
  newQuantity Decimal  @map("new_quantity") @db.Decimal(12, 3)
  reason      String   @db.VarChar(120)
  adjustedAt  DateTime @default(now()) @map("adjusted_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([materialId])
  @@index([adjustedAt])
  @@map("stock_adjustments")
}

model ShopPayment {
  id          Int      @id @default(autoincrement())
  shopId      Int      @map("shop_id")
  amount      Decimal  @db.Decimal(14, 2)
  paymentDate DateTime @map("payment_date") @db.Date
  description String?  @db.VarChar(255)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([shopId])
  @@index([paymentDate])
  @@map("shop_payments")
}
